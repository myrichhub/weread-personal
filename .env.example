# Copy this file to .env and fill in your actual values
# .env is gitignored and will NEVER be committed

# MySQL
DB_URL=jdbc:mysql://mysql:3306/weread?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8
DB_USERNAME=weread
DB_PASSWORD=your_db_password_here

# JWT signing secret (generate a long random string)
JWT_SECRET=your_very_long_jwt_secret_here_at_least_32_chars

# Server port
SERVER_PORT=8080
FRONTEND_PORT=3000
